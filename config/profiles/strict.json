{
  "rules": {
    "nihongo-slopless/hidden-unicode-controls": "error",
    "nihongo-slopless/placeholder": "error",
    "nihongo-slopless/chat-response-leakage": "warning",
    "nihongo-slopless/list-intro-padding": "warning",
    "nihongo-slopless/long-sentence": ["warning", { "maxChars": 90, "errorChars": 140 }],
    "nihongo-slopless/long-paragraph": ["warning", { "maxChars": 320, "maxSentences": 4 }],
    "nihongo-slopless/empty-conclusion": "warning",
    "nihongo-slopless/weasel-phrases": ["warning", { "maxPerParagraph": 1 }],
    "nihongo-slopless/citation-needed": "warning",
    "nihongo-slopless/absolute-claim": "warning",
    "nihongo-slopless/abstract-noun-stack": ["warning", { "minHits": 3 }],
    "nihongo-slopless/nominalization-density": ["warning", { "minHits": 5, "minChars": 50 }],
    "nihongo-slopless/excessive-politeness": ["warning", { "maxSasetePerParagraph": 1 }],
    "nihongo-slopless/actorless-action": "warning",
    "nihongo-slopless/same-ending": "warning",
    "nihongo-slopless/repeated-connectors": "warning",
    "nihongo-slopless/translationese": ["warning", { "maxPerParagraph": 3 }],
    "nihongo-slopless/buzzword-density": ["warning", { "maxPerParagraph": 2 }],
    "nihongo-slopless/thin-sentence": "warning",
    "nihongo-slopless/excessive-parentheses": "warning",
    "nihongo-slopless/headline-decoration": "warning",
    "nihongo-slopless/unscoped-generalization": "error",
    "nihongo-slopless/no-numerics-claim": "error",
    "nihongo-slopless/deadline-missing": "error",
    "nihongo-slopless/over-possibility": "error",
    "nihongo-slopless/unclear-deictic": "error"
  }
}
